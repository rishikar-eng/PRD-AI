# OpenAI — used by writer, intake, specialists, success metric, quality gate, claude-context, stage2 handoff
OPENAI_API_KEY=your-openai-key-here

# Anthropic — used by the debate agent only (better at nuanced meta-reasoning across specialists)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Rian API
RIAN_API_BASE_URL=https://api.rian.io/v1
RIAN_API_KEY=your-rian-api-key-here

# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=generate-a-long-random-string-minimum-64-chars
CORS_ORIGIN=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Persistent session storage (Supabase Postgres via Session pooler)
# Copy from Supabase dashboard → Project Settings → Database → Connection string → "Session" mode.
# Format: postgresql://postgres.PROJECTREF:PASSWORD@aws-0-<REGION>.pooler.supabase.com:5432/postgres
# Leave blank to use in-memory sessions (NOT recommended — dies on every restart).
DATABASE_URL=

# Microsoft Teams notifications (optional)
# URL of a Power Automate "Post to a channel when a webhook request is received"
# flow. Created by an M365 admin once per Teams channel. Leave blank to disable.
TEAMS_WEBHOOK_URL=
